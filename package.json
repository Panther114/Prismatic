{
  "name": "prismatic",
  "version": "1.2.0",
  "private": true,
  "author": "Prismatic",
  "description": "Prismatic — cinematic music visualizer & player. Browser-side export keeps the host lightweight.",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "start": "cross-env NODE_ENV=production node dist-server/index.mjs",
    "start:ts": "cross-env NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm build && pnpm build:server",
    "prepare:sample": "tsx scripts/prepare-sample.ts",
    "render:sample": "tsx scripts/render-sample.ts",
    "stage:desktop": "node scripts/stage-desktop.mjs",
    "electron:dev": "pnpm build && pnpm build:server && cross-env NODE_ENV=production PRISMATIC_LOCAL=1 electron .",
    "electron:build": "pnpm build && pnpm build:server && node scripts/stage-desktop.mjs && electron-builder --win nsis --config electron-builder.yml",
    "dist:win": "pnpm electron:build && node scripts/verify-installer.mjs",
    "verify:installer": "node scripts/verify-installer.mjs"
  },
  "dependencies": {
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/ibm-plex-sans": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "cross-env": "^7.0.3",
    "express": "^5.1.0",
    "fft.js": "^4.0.4",
    "lucide-react": "^0.525.0",
    "multer": "^2.0.2",
    "music-metadata": "^11.8.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.5"
  },
  "packageManager": "pnpm@11.7.0"
}
